# =============================================================================
# UniConnect AI Student Support Chatbot - Environment Configuration Example
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_NAME=UniConnect
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- PostgreSQL Database ---
POSTGRES_USER=uniconnect
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=uniconnect_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://uniconnect:your_password_here@db:5432/uniconnect_db

# --- JWT Authentication ---
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=uniconnect_knowledge

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.txt

# --- RAG Configuration ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SIMILARITY_TOP_K=5
CONFIDENCE_THRESHOLD=0.65

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
